local mainModule = require(script:WaitForChild("Main"))

local function init(player)
	if player then
		print(player.Name.." Has joined, searching for classic face.")
		local foundFace = mainModule.FindFace(player)
		if foundFace then
			local newData = mainModule.AssignFace(player, foundFace)

			mainModule.LoadFaceOnChar(player.Character, newData)

			player.CharacterAdded:Connect(function(char)
				mainModule.LoadFaceOnChar(char, newData)
			end)
		end
	end
end

mainModule.LoadFaces()

for i, player in pairs(game.Players:GetPlayers()) do
	init(player)
end

game.Players.PlayerAdded:Connect(init)


